# Finnhub API Key (Free tier available)
# Get your free API key from: https://finnhub.io/register
# Rename this file to .env.local and add your key below
VITE_FINNHUB_API_KEY=your_api_key_here

# Note: Free tier limits:
# - 60 API calls per minute
# - Real-time news and market data
# - Sentiment analysis

# ─── TradeRadar Bot (MVP) ──────────────────────────────────────────────────
# Supabase (create project → Settings → API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...            # frontend read (dashboard history)
SUPABASE_URL=https://xxxx.supabase.co    # server (cron writes) — same URL
SUPABASE_SERVICE_KEY=eyJ...              # service_role key — SERVER ONLY, never prefix VITE_

# Telegram (BotFather → /newbot for token; chat id via @userinfobot)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# Claude — optional. Without it the bot runs in demo mode (deterministic report, RM0).
ANTHROPIC_API_KEY=sk-ant-...

# Protect the cron endpoint. Any long random string; use the same value in your cron trigger.
CRON_SECRET=change-me-to-something-long-and-random
